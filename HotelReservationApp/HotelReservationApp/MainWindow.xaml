<Window x:Class="HotelReservationApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hotel Reservation App" Height="500" Width="800">

    <Grid Margin="10">
        <StackPanel>

            <!-- INPUT FORM -->
           

            <DatePicker SelectedDate="{Binding CheckIn}" Margin="0,5"/>
            <DatePicker SelectedDate="{Binding CheckOut}" Margin="0,5"/>

            <!-- BUTTONS -->
            <StackPanel Orientation="Horizontal" Margin="0,10">
                <Button Content="Add" Width="100"
                        Command="{Binding AddReservationCommand}" Margin="5"/>

                <Button Content="Delete" Width="100"
                        Command="{Binding DeleteReservationCommand}" Margin="5"/>
            </StackPanel>

            <!-- DATA GRID -->
            <DataGrid ItemsSource="{Binding Reservations}"
                      SelectedItem="{Binding SelectedReservation}"
                      AutoGenerateColumns="False"
                      Height="250">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Guest" Binding="{Binding GuestName}" Width="*"/>
                    <DataGridTextColumn Header="Room ID" Binding="{Binding ReservedRoom.RoomID}" Width="*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding ReservedRoom.Type}" Width="*"/>
                    <DataGridTextColumn Header="Check In" Binding="{Binding CheckIn}" Width="*"/>
                    <DataGridTextColumn Header="Check Out" Binding="{Binding CheckOut}" Width="*"/>
                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>
    </Grid>
</Window>